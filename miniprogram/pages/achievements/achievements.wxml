<view class="page">
  <!-- 成就总览 -->
  <view class="card overview-card">
    <text class="overview-title">已解锁成就</text>
    <view class="overview-num">
      <text class="num-current">{{unlockedCount}}</text>
      <text class="num-total">/ {{totalCount}}</text>
    </view>
    <view class="overview-bar-bg">
      <view class="overview-bar-fill" style="width: {{progressPercent}}%;"></view>
    </view>
  </view>

  <!-- 成就列表 -->
  <view class="card">
    <text class="section-title">全部成就</text>
    <view wx:for="{{achievementList}}" wx:key="id" class="achievement-item {{item.unlocked ? 'unlocked' : 'locked'}}">
      <view class="ach-icon-wrap {{item.unlocked ? '' : 'locked'}}">
        <image class="ach-icon" src="{{item.icon}}" mode="aspectFit"></image>
      </view>
      <view class="ach-info">
        <text class="ach-name">{{item.name}}</text>
        <text class="ach-desc">{{item.desc}}</text>
        <text wx:if="{{item.unlocked}}" class="ach-time">{{item.unlockTime}}</text>
      </view>
      <view wx:if="{{item.unlocked}}" class="ach-badge">
        <text>已达成</text>
      </view>
      <view wx:else class="ach-progress">
        <text>{{item.progressText || '未达成'}}</text>
      </view>
    </view>
  </view>
</view>
