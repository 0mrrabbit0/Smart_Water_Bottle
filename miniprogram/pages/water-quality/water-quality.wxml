<view class="page">
  <!-- 综合评级 -->
  <view class="card grade-card">
    <view class="grade-badge" style="border-color: {{overallGrade.color}};">
      <text class="grade-label" style="color: {{overallGrade.color}};">{{overallGrade.label}}</text>
      <text class="grade-letter" style="color: {{overallGrade.color}};">{{overallGrade.grade}}</text>
    </view>
    <view class="grade-info">
      <text class="grade-tds">TDS: {{tds !== null ? tds : '--'}} ppm</text>
      <text class="grade-time">更新时间: {{updateTime}}</text>
    </view>
  </view>

  <!-- 详细参数 -->
  <view class="card">
    <text class="section-title">水质参数</text>

    <quality-gauge
      label="TDS (溶解性固体)"
      value="{{tds}}"
      unit="ppm"
      percent="{{tdsPercent}}"
      color="{{tdsGrade.color}}"
      gradeLabel="{{tdsGrade.label}}"
    />

    <quality-gauge
      label="EC (电导率)"
      value="{{ec}}"
      unit="us/cm"
      percent="{{ecPercent}}"
      color="{{ecGrade.color}}"
      gradeLabel="{{ecGrade.label}}"
    />

    <quality-gauge
      label="盐度"
      value="{{salinity}}"
      unit="%"
      percent="{{salinityPercent}}"
      color="{{salinityGrade.color}}"
      gradeLabel="{{salinityGrade.label}}"
    />

    <quality-gauge
      label="硬度"
      value="{{hardness}}"
      unit="ppm"
      percent="{{hardnessPercent}}"
      color="{{hardnessGrade.color}}"
      gradeLabel="{{hardnessGrade.label}}"
    />
  </view>

  <!-- 历史趋势 -->
  <view class="card">
    <view class="flex-between" style="margin-bottom: 20rpx;">
      <text class="section-title" style="margin-bottom:0;">TDS 趋势</text>
      <view class="period-tabs">
        <text class="period-tab {{period === '7' ? 'active' : ''}}" bindtap="setPeriod" data-period="7">7天</text>
        <text class="period-tab {{period === '30' ? 'active' : ''}}" bindtap="setPeriod" data-period="30">30天</text>
      </view>
    </view>

    <view class="trend-chart" wx:if="{{historyData.length > 0}}">
      <view class="chart-area">
        <view class="chart-y-axis">
          <text>{{yMax}}</text>
          <text>{{yMid}}</text>
          <text>0</text>
        </view>
        <view class="chart-bars">
          <view wx:for="{{historyData}}" wx:key="date" class="chart-bar-item">
            <view class="chart-bar" style="height: {{item.percent}}%; background: {{item.color}};"></view>
          </view>
        </view>
      </view>
      <view class="chart-x-labels">
        <text wx:for="{{historyLabels}}" wx:key="*this">{{item}}</text>
      </view>
    </view>
    <view wx:else class="empty-chart">
      <text>暂无历史数据</text>
    </view>
  </view>

  <!-- 水质知识 -->
  <view class="card">
    <text class="section-title">水质小知识</text>
    <view class="knowledge-list">
      <view wx:for="{{knowledgeList}}" wx:key="title" class="knowledge-item">
        <text class="knowledge-title">{{item.title}}</text>
        <text class="knowledge-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>
</view>
