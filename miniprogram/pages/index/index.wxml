<view class="page">
  <!-- 蓝牙连接状态 -->
  <ble-status
    connected="{{connected}}"
    deviceName="{{deviceName}}"
    bind:tap="onBleStatusTap"
  />

  <!-- 饮水进度环 -->
  <view class="card progress-section">
    <progress-ring current="{{dailyTotal}}" goal="{{dailyGoal}}" />
    <view class="progress-tip" wx:if="{{dailyTotal >= dailyGoal}}">
      <text class="tip-text tip-success">今日目标已达成!</text>
    </view>
    <view class="progress-tip" wx:else>
      <text class="tip-text">还需 {{dailyGoal - dailyTotal}} ml 达成今日目标</text>
    </view>
  </view>

  <!-- 数据卡片 -->
  <view class="data-grid">
    <view class="grid-item">
      <data-card
        icon="/static/icons/temp.png"
        iconBg="#FFF7E6"
        value="{{deviceData.temperature !== null ? deviceData.temperature : '--'}}"
        unit="°C"
        label="水温"
        status="{{tempStatus.label}}"
        statusColor="{{tempStatus.color}}"
      />
    </view>
    <view class="grid-item">
      <data-card
        icon="/static/icons/tds.png"
        iconBg="#E6F7FF"
        value="{{deviceData.tds !== null ? deviceData.tds : '--'}}"
        unit="ppm"
        label="TDS水质"
        status="{{tdsStatus.label}}"
        statusColor="{{tdsStatus.color}}"
      />
    </view>
    <view class="grid-item">
      <data-card
        icon="/static/icons/waterlevel.png"
        iconBg="#E6FFFB"
        value="{{waterLevelText}}"
        unit=""
        label="水位"
      />
    </view>
    <view class="grid-item">
      <data-card
        icon="/static/icons/battery.png"
        iconBg="{{batteryStatus.color === '#F5222D' ? '#FFF1F0' : '#F6FFED'}}"
        value="{{deviceData.battery !== null ? deviceData.battery : '--'}}"
        unit="%"
        label="电量"
        status="{{batteryStatus.label}}"
        statusColor="{{batteryStatus.color}}"
      />
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="action-bar">
    <view class="action-btn action-drink" bindtap="onDrinkTap">
      <image class="action-icon" src="/static/icons/add-water.png" mode="aspectFit"></image>
      <text>记录饮水</text>
    </view>
    <view class="action-btn action-unlock" bindtap="onUnlockTap">
      <image class="action-icon" src="/static/icons/unlock.png" mode="aspectFit"></image>
      <text>远程开锁</text>
    </view>
  </view>

  <!-- 饮水量选择弹窗 -->
  <view class="modal-mask" wx:if="{{showDrinkModal}}" bindtap="closeDrinkModal">
    <view class="modal-content" catchtap>
      <text class="modal-title">记录饮水</text>
      <view class="drink-options">
        <view
          wx:for="{{drinkAmounts}}"
          wx:key="*this"
          class="drink-option {{selectedAmount === item ? 'selected' : ''}}"
          bindtap="selectAmount"
          data-amount="{{item}}"
        >
          <text class="option-amount">{{item}}</text>
          <text class="option-unit">ml</text>
        </view>
      </view>
      <view class="custom-amount">
        <text class="custom-label">自定义</text>
        <input
          class="custom-input"
          type="number"
          placeholder="输入ml"
          value="{{customAmount}}"
          bindinput="onCustomInput"
        />
      </view>
      <view class="modal-actions">
        <view class="modal-btn cancel" bindtap="closeDrinkModal">取消</view>
        <view class="modal-btn confirm" bindtap="confirmDrink">确认记录</view>
      </view>
    </view>
  </view>

  <!-- 开锁密码弹窗 -->
  <view class="modal-mask" wx:if="{{showUnlockModal}}" bindtap="closeUnlockModal">
    <view class="modal-content" catchtap>
      <text class="modal-title">远程开锁</text>
      <text class="modal-desc">请输入3位数字密码</text>
      <input
        class="unlock-input"
        type="number"
        maxlength="3"
        placeholder="输入密码"
        value="{{unlockPassword}}"
        bindinput="onPasswordInput"
        focus="{{showUnlockModal}}"
      />
      <view class="modal-actions">
        <view class="modal-btn cancel" bindtap="closeUnlockModal">取消</view>
        <view class="modal-btn confirm" bindtap="confirmUnlock">确认开锁</view>
      </view>
    </view>
  </view>
</view>
