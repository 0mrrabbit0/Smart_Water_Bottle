<view class="page">
  <!-- 已绑定设备信息 -->
  <view class="card device-card" wx:if="{{boundDevice}}">
    <view class="device-header">
      <view class="device-icon-wrap">
        <image class="device-icon" src="/static/icons/bottle.png" mode="aspectFit"></image>
      </view>
      <view class="device-info">
        <text class="device-name">{{boundDevice.name}}</text>
        <text class="device-mac">MAC: {{boundDevice.deviceId}}</text>
      </view>
      <view class="device-status {{connected ? 'online' : 'offline'}}">
        <view class="status-dot"></view>
        <text>{{connected ? '在线' : '离线'}}</text>
      </view>
    </view>

    <view class="device-actions">
      <view class="device-action" bindtap="onConnect" wx:if="{{!connected}}">
        <text>连接设备</text>
      </view>
      <view class="device-action disconnect" bindtap="onDisconnect" wx:else>
        <text>断开连接</text>
      </view>
      <view class="device-action" bindtap="syncTime" wx:if="{{connected}}">
        <text>同步时间</text>
      </view>
      <view class="device-action" bindtap="changePassword" wx:if="{{connected}}">
        <text>修改密码</text>
      </view>
    </view>
  </view>

  <!-- 扫描设备 -->
  <view class="card">
    <view class="flex-between" style="margin-bottom: 20rpx;">
      <text class="section-title" style="margin-bottom:0;">扫描设备</text>
      <view class="scan-btn {{scanning ? 'scanning' : ''}}" bindtap="startScan">
        <text>{{scanning ? '扫描中...' : '开始扫描'}}</text>
      </view>
    </view>

    <view wx:if="{{scanning}}" class="scan-loading">
      <view class="loading-spinner"></view>
      <text>正在搜索附近的智能水杯...</text>
    </view>

    <view wx:if="{{!scanning && deviceList.length === 0}}" class="scan-empty">
      <text>未发现设备，请确保水杯蓝牙已开启</text>
    </view>

    <view wx:for="{{deviceList}}" wx:key="deviceId" class="device-list-item" bindtap="selectDevice" data-index="{{index}}">
      <view class="list-item-info">
        <text class="list-item-name">{{item.name}}</text>
        <text class="list-item-id">{{item.deviceId}}</text>
      </view>
      <view class="list-item-rssi">
        <view class="rssi-bars">
          <view class="rssi-bar {{item.RSSI > -90 ? 'active' : ''}}"></view>
          <view class="rssi-bar {{item.RSSI > -75 ? 'active' : ''}}"></view>
          <view class="rssi-bar {{item.RSSI > -60 ? 'active' : ''}}"></view>
          <view class="rssi-bar {{item.RSSI > -45 ? 'active' : ''}}"></view>
        </view>
        <text class="rssi-text">{{item.RSSI}}dBm</text>
      </view>
    </view>
  </view>

  <!-- 设备设置 -->
  <view class="card" wx:if="{{boundDevice}}">
    <text class="section-title">设备设置</text>
    <view class="setting-item">
      <text class="setting-label">数据上报间隔</text>
      <picker mode="selector" range="{{intervalOptions}}" range-key="label" value="{{intervalIdx}}" bindchange="onIntervalChange">
        <text class="setting-value">{{intervalOptions[intervalIdx].label}}</text>
      </picker>
    </view>
    <view class="divider"></view>
    <view class="setting-item" bindtap="unbindDevice">
      <text class="setting-label" style="color: #F5222D;">解绑设备</text>
    </view>
  </view>
</view>
