<view class="page">
  <!-- 视图切换 -->
  <view class="tab-bar">
    <view class="tab {{activeTab === 'week' ? 'active' : ''}}" bindtap="switchTab" data-tab="week">周</view>
    <view class="tab {{activeTab === 'month' ? 'active' : ''}}" bindtap="switchTab" data-tab="month">月</view>
  </view>

  <!-- 汇总数据 -->
  <view class="card summary">
    <view class="summary-item">
      <text class="summary-value">{{totalAmount}}</text>
      <text class="summary-label">总饮水量(ml)</text>
    </view>
    <view class="summary-item">
      <text class="summary-value">{{avgAmount}}</text>
      <text class="summary-label">日均(ml)</text>
    </view>
    <view class="summary-item">
      <text class="summary-value">{{achievedDays}}/{{totalDays}}</text>
      <text class="summary-label">达标天数</text>
    </view>
    <view class="summary-item">
      <text class="summary-value">{{goalRate}}%</text>
      <text class="summary-label">达标率</text>
    </view>
  </view>

  <!-- 周视图 - 柱状图 -->
  <view class="card" wx:if="{{activeTab === 'week'}}">
    <text class="section-title">每日饮水量</text>
    <view class="bar-chart">
      <view wx:for="{{chartData}}" wx:key="date" class="bar-col">
        <text class="bar-value">{{item.amount > 0 ? item.amount : ''}}</text>
        <view class="bar-track">
          <view class="bar-fill {{item.achieved ? 'achieved' : ''}}" style="height: {{item.percent}}%;"></view>
        </view>
        <text class="bar-label">{{item.label}}</text>
      </view>
    </view>
    <view class="goal-line-label">
      <view class="goal-line-dot"></view>
      <text>目标 {{dailyGoal}}ml</text>
    </view>
  </view>

  <!-- 月视图 - 日历热力图 -->
  <view class="card" wx:if="{{activeTab === 'month'}}">
    <view class="flex-between" style="margin-bottom: 20rpx;">
      <text class="section-title" style="margin-bottom:0;">{{monthLabel}}</text>
      <view class="month-nav">
        <text class="nav-btn" bindtap="prevMonth">＜</text>
        <text class="nav-btn" bindtap="nextMonth">＞</text>
      </view>
    </view>

    <view class="calendar-header">
      <text wx:for="{{weekDays}}" wx:key="*this" class="cal-weekday">{{item}}</text>
    </view>

    <view class="calendar-grid">
      <view wx:for="{{calendarDays}}" wx:key="index" class="cal-day {{item.empty ? 'empty' : ''}}">
        <view wx:if="{{!item.empty}}" class="cal-day-inner" style="background: {{item.color}};">
          <text class="cal-day-num">{{item.day}}</text>
        </view>
      </view>
    </view>

    <view class="heatmap-legend">
      <text class="legend-label">少</text>
      <view class="legend-block" style="background: #F0F0F0;"></view>
      <view class="legend-block" style="background: #BAE7FF;"></view>
      <view class="legend-block" style="background: #69C0FF;"></view>
      <view class="legend-block" style="background: #1890FF;"></view>
      <view class="legend-block" style="background: #0050B3;"></view>
      <text class="legend-label">多</text>
    </view>
  </view>

  <!-- 记录列表 -->
  <view class="card">
    <text class="section-title">详细记录</text>
    <view wx:for="{{detailList}}" wx:key="date" class="detail-item">
      <view class="detail-date">
        <text class="detail-day">{{item.dateLabel}}</text>
        <text class="detail-weekday">{{item.weekday}}</text>
      </view>
      <view class="detail-bar-bg">
        <view class="detail-bar-fill {{item.achieved ? 'achieved' : ''}}" style="width: {{item.percent}}%;"></view>
      </view>
      <text class="detail-amount">{{item.amount}}ml</text>
    </view>
  </view>
</view>
