.page {
  padding: 16rpx 0 40rpx;
}

/* 今日概览 */
.summary-card {
  background: linear-gradient(135deg, #1890FF, #69C0FF);
  color: #FFFFFF;
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.summary-date {
  font-size: 28rpx;
  opacity: 0.9;
}

.goal-setting {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.goal-text {
  font-size: 24rpx;
  opacity: 0.8;
}

.goal-edit {
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.summary-body {
  text-align: center;
}

.summary-main {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 20rpx;
}

.summary-amount {
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1;
}

.summary-unit {
  font-size: 28rpx;
  margin-left: 8rpx;
  opacity: 0.8;
}

.summary-bar-bg {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
  margin-bottom: 24rpx;
}

.summary-bar-fill {
  height: 100%;
  background: #FFFFFF;
  border-radius: 6rpx;
  transition: width 0.6s ease;
  max-width: 100%;
}

.summary-stats {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.7;
  margin-top: 4rpx;
}

/* 快速记录 */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 20rpx;
  display: block;
}

.quick-btns {
  display: flex;
  gap: 16rpx;
}

.quick-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  background: #F5F7FA;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.quick-btn:active {
  background: #E6F7FF;
}

.quick-btn.custom {
  background: #E6F7FF;
}

.quick-amount {
  font-size: 32rpx;
  font-weight: 600;
  color: #262626;
}

.quick-unit {
  font-size: 22rpx;
  color: #8C8C8C;
  margin-top: 4rpx;
}

/* 提醒设置 */
.reminder-label {
  font-size: 26rpx;
  color: #595959;
}

.reminder-value {
  font-size: 26rpx;
  color: #1890FF;
}

/* 查看统计 */
.view-stats {
  font-size: 24rpx;
  color: #1890FF;
}

/* 周统计 */
.week-chart {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 200rpx;
  padding: 0 16rpx;
}

.week-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.week-bar-bg {
  width: 32rpx;
  height: 160rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
}

.week-bar-fill {
  width: 100%;
  background: #BFBFBF;
  border-radius: 8rpx;
  transition: height 0.4s ease;
}

.week-bar-fill.achieved {
  background: #1890FF;
}

.week-label {
  font-size: 20rpx;
  color: #8C8C8C;
  margin-top: 8rpx;
}

.week-legend {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #8C8C8C;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  background: #BFBFBF;
}

.legend-dot.achieved {
  background: #1890FF;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #262626;
  text-align: center;
  display: block;
  margin-bottom: 32rpx;
}

.goal-slider-area {
  padding: 20rpx 0;
}

.goal-display {
  font-size: 48rpx;
  font-weight: 700;
  color: #1890FF;
  text-align: center;
  display: block;
  margin-bottom: 24rpx;
}

.goal-range {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #8C8C8C;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  background: #F5F5F5;
  color: #595959;
}

.modal-btn.confirm {
  background: #1890FF;
  color: #FFFFFF;
}
