.page {
  padding: 16rpx 0 40rpx;
}

/* 用户信息卡 */
.user-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #1890FF, #69C0FF);
  color: #FFFFFF;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
}

.user-desc {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 4rpx;
  display: block;
}

.edit-btn {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 24rpx;
}

/* 统计卡 */
.stats-card {
  padding: 32rpx 24rpx;
}

.stats-row {
  display: flex;
  align-items: center;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #1890FF;
  display: block;
}

.stats-label {
  font-size: 22rpx;
  color: #8C8C8C;
  margin-top: 4rpx;
  display: block;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: #F0F0F0;
}

/* 菜单 */
.menu-card {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #262626;
}

.menu-extra {
  margin-right: 12rpx;
}

.menu-hint {
  font-size: 24rpx;
  color: #8C8C8C;
}

.menu-arrow {
  font-size: 28rpx;
  color: #D9D9D9;
}

.menu-divider {
  height: 1rpx;
  background: #F0F0F0;
  margin: 0 24rpx;
}

.device-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.device-status.online {
  background: #F6FFED;
  color: #52C41A;
}

.device-status.offline {
  background: #F5F5F5;
  color: #8C8C8C;
}

.badge-count {
  background: #F5222D;
  color: #FFFFFF;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 16rpx;
  padding: 0 8rpx;
}
