<view class="page">
  <!-- 用户信息卡 -->
  <view class="card user-card">
    <image class="avatar" src="{{userInfo.avatar_url || '/static/images/default-avatar.png'}}" mode="aspectFill"></image>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname || '未登录'}}</text>
      <text class="user-desc">已坚持饮水 {{streakDays}} 天</text>
    </view>
    <view class="edit-btn" bindtap="editProfile">编辑</view>
  </view>

  <!-- 数据统计卡 -->
  <view class="card stats-card">
    <view class="stats-row">
      <view class="stats-item" bindtap="goStats">
        <text class="stats-num">{{totalDrink}}</text>
        <text class="stats-label">累计饮水(L)</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item" bindtap="goAchievements">
        <text class="stats-num">{{achievementCount}}</text>
        <text class="stats-label">获得成就</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <text class="stats-num">{{avgGoalRate}}%</text>
        <text class="stats-label">月达标率</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="card menu-card">
    <view class="menu-item" bindtap="goDevice">
      <image class="menu-icon" src="/static/icons/device.png" mode="aspectFit"></image>
      <text class="menu-text">设备管理</text>
      <view class="menu-extra">
        <text class="device-status {{connected ? 'online' : 'offline'}}">{{connected ? '已连接' : '未连接'}}</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-divider"></view>

    <view class="menu-item" bindtap="goStats">
      <image class="menu-icon" src="/static/icons/stats.png" mode="aspectFit"></image>
      <text class="menu-text">饮水统计</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-divider"></view>

    <view class="menu-item" bindtap="goAchievements">
      <image class="menu-icon" src="/static/icons/achievement.png" mode="aspectFit"></image>
      <text class="menu-text">我的成就</text>
      <view class="menu-extra">
        <text class="badge-count" wx:if="{{newAchievements > 0}}">{{newAchievements}}</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- 个人设置 -->
  <view class="card menu-card">
    <view class="menu-item" bindtap="editBodyInfo">
      <image class="menu-icon" src="/static/icons/body.png" mode="aspectFit"></image>
      <text class="menu-text">身体信息</text>
      <view class="menu-extra">
        <text class="menu-hint">{{userInfo.weight ? userInfo.weight + 'kg' : '未设置'}}</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-divider"></view>

    <view class="menu-item" bindtap="editGoal">
      <image class="menu-icon" src="/static/icons/target.png" mode="aspectFit"></image>
      <text class="menu-text">每日目标</text>
      <view class="menu-extra">
        <text class="menu-hint">{{dailyGoal}}ml</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-divider"></view>

    <view class="menu-item">
      <image class="menu-icon" src="/static/icons/remind.png" mode="aspectFit"></image>
      <text class="menu-text">饮水提醒</text>
      <switch checked="{{reminderEnabled}}" bindchange="toggleReminder" color="#1890FF" style="transform: scale(0.8);" />
    </view>
  </view>

  <!-- 其他 -->
  <view class="card menu-card">
    <view class="menu-item" bindtap="shareApp">
      <image class="menu-icon" src="/static/icons/share.png" mode="aspectFit"></image>
      <text class="menu-text">分享给好友</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-divider"></view>

    <view class="menu-item" bindtap="showAbout">
      <image class="menu-icon" src="/static/icons/about.png" mode="aspectFit"></image>
      <text class="menu-text">关于</text>
      <view class="menu-extra">
        <text class="menu-hint">v1.0.0</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>
