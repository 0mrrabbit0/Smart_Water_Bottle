.ble-status {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  margin: 0 24rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.ble-status.connected {
  background: rgba(82, 196, 26, 0.1);
  color: #52C41A;
}

.ble-status.disconnected {
  background: rgba(140, 140, 140, 0.1);
  color: #8C8C8C;
}

.ble-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.connected .ble-dot {
  background: #52C41A;
}

.disconnected .ble-dot {
  background: #8C8C8C;
}

.ble-text {
  font-weight: 500;
}

.ble-name {
  margin-left: 12rpx;
  color: inherit;
  opacity: 0.8;
}

.ble-action {
  margin-left: auto;
  font-size: 22rpx;
  color: #1890FF;
}
