<view class="data-card" style="background: {{bgColor || '#FFFFFF'}};">
  <view class="card-icon-wrap" style="background: {{iconBg || '#E6F7FF'}};">
    <image class="card-icon" src="{{icon}}" mode="aspectFit"></image>
  </view>
  <view class="card-content">
    <view class="card-value-row">
      <text class="card-value" style="color: {{valueColor || '#262626'}};">{{value}}</text>
      <text class="card-unit">{{unit}}</text>
    </view>
    <text class="card-label">{{label}}</text>
  </view>
  <view wx:if="{{status}}" class="card-status" style="color: {{statusColor || '#52C41A'}};">
    <text>{{status}}</text>
  </view>
</view>
