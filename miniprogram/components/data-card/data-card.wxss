.data-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.card-icon {
  width: 44rpx;
  height: 44rpx;
}

.card-content {
  flex: 1;
}

.card-value-row {
  display: flex;
  align-items: baseline;
}

.card-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #262626;
  line-height: 1.2;
}

.card-unit {
  font-size: 22rpx;
  color: #8C8C8C;
  margin-left: 6rpx;
}

.card-label {
  font-size: 24rpx;
  color: #8C8C8C;
  margin-top: 4rpx;
}

.card-status {
  font-size: 22rpx;
  font-weight: 500;
  flex-shrink: 0;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(82, 196, 26, 0.1);
}
