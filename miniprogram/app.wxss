/* 全局样式 */
page {
  background-color: #F5F7FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', Arial, sans-serif;
  font-size: 28rpx;
  color: #262626;
  box-sizing: border-box;
}

/* 色彩变量 */
:root {
  --primary: #1890FF;
  --primary-light: #E6F7FF;
  --success: #52C41A;
  --warning: #FAAD14;
  --danger: #F5222D;
  --info: #1890FF;
  --text-primary: #262626;
  --text-regular: #595959;
  --text-secondary: #8C8C8C;
  --border: #F0F0F0;
  --bg-page: #F5F7FA;
  --bg-card: #FFFFFF;
}

/* 通用卡片 */
.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 弹性布局 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

/* 文字样式 */
.text-primary { color: #1890FF; }
.text-success { color: #52C41A; }
.text-warning { color: #FAAD14; }
.text-danger { color: #F5222D; }
.text-secondary { color: #8C8C8C; }

/* 按钮 */
.btn-primary {
  background: #1890FF;
  color: #FFFFFF;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

.btn-primary:active {
  background: #096DD9;
}

.btn-outline {
  background: #FFFFFF;
  color: #1890FF;
  border: 2rpx solid #1890FF;
  border-radius: 12rpx;
  padding: 18rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #F0F0F0;
  margin: 24rpx 0;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
}
